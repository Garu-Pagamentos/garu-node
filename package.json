{
  "name": "@garuhq/node",
  "version": "0.5.0",
  "description": "Official Node.js / TypeScript SDK for the Garu payment gateway.",
  "license": "MIT",
  "homepage": "https://garu.com.br",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Garu-Pagamentos/garu-node.git"
  },
  "bugs": {
    "url": "https://github.com/Garu-Pagamentos/garu-node/issues"
  },
  "keywords": [
    "garu",
    "payments",
    "pix",
    "boleto",
    "credit-card",
    "brazil",
    "fintech",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:fetch": "curl -sf ${GARU_SPEC_URL:-https://garu.com.br/api/swagger-json} -o src/generated/openapi.json",
    "generate:filter": "node scripts/filter-spec.mjs",
    "generate": "npm run generate:fetch && npm run generate:filter && openapi-typescript src/generated/openapi-sdk.json -o src/generated/schema.d.ts",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@types/node": "20.12.7",
    "openapi-typescript": "7.4.2",
    "tsup": "8.5.1",
    "typescript": "5.4.5",
    "vitest": "3.2.4"
  },
  "dependencies": {
    "openapi-fetch": "0.9.7"
  }
}
